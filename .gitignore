# =========================
# Python cache / build
# =========================
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE / editor
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# OS / misc
.DS_Store
Thumbs.db

# Logs / temp
*.log
*.tmp
*.bak
tmp/
temp/
tempt/

# =========================
# Project-specific sensitive files
# =========================
# App settings may contain API keys / credentials
**/app_settings*.json

# Translation history data and other local runtime JSON files
**/translation_history*.json
**/*.resume.json

# Common secret files
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*.crt
*.csr

